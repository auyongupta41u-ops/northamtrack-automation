# ════════════════════════════════════════════════════════════════════════════════
# NORTHAMTRACK REGULATORY AUTOMATION — ENVIRONMENT CONFIGURATION
# Version 2.0
# 
# Copy this file to .env and fill in your actual values
# ════════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Your Supabase project URL
# Get from: https://app.supabase.com/project/[project-id]/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (for backend automation)
# Get from: https://app.supabase.com/project/[project-id]/settings/api
# ⚠️  IMPORTANT: Use Service Role Key, NOT Anon Key
# ⚠️  Keep this secret! Never commit to version control
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ════════════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION (For browser-based access)
# ════════════════════════════════════════════════════════════════════════════════

# Supabase Anon Key (for frontend - safe to expose)
# Get from: https://app.supabase.com/project/[project-id]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ════════════════════════════════════════════════════════════════════════════════
# AUTOMATION SETTINGS
# ════════════════════════════════════════════════════════════════════════════════

# Run ID for tracking (optional - auto-generated if not set)
RUN_ID=manual-run

# Enable/disable specific regulators (true/false)
ENABLE_SEC=true
ENABLE_OSC=true
ENABLE_CSA=true
ENABLE_BCSC=true
ENABLE_ASC=true
ENABLE_AMF=true
ENABLE_FCAA=true
ENABLE_CIRO=true

# ════════════════════════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════════════════════════

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ════════════════════════════════════════════════════════════════════════════════
# NOTES
# ════════════════════════════════════════════════════════════════════════════════

# How to get Supabase credentials:
# 1. Go to https://app.supabase.com
# 2. Create a new project or select existing one
# 3. Go to Settings → API
# 4. Copy the Project URL and Service Role Key
# 5. Paste them here in .env
#
# For GitHub Actions:
# 1. Go to your GitHub repository
# 2. Settings → Secrets and variables → Actions
# 3. Add SUPABASE_URL and SUPABASE_SERVICE_KEY
# 4. GitHub Actions will automatically use these secrets
